# Infinity ID — environment configuration (copy to `.env`).
# These override Config.toml. Never commit the real .env.

INFINITY_BIND=0.0.0.0:8080
INFINITY_ISSUER=http://localhost:8080
INFINITY_DATABASE_URL=sqlite://data/infinity.db
INFINITY_DATA_DIR=data

# Strong seed admin password (first run only). If omitted, one is generated.
INFINITY_ADMIN_EMAIL=admin@infinity.local
INFINITY_ADMIN_PASSWORD=change-me-to-a-long-random-value

INFINITY_ACCESS_TOKEN_TTL_SECS=3600
INFINITY_REFRESH_TOKEN_TTL_SECS=2592000
INFINITY_GLOBAL_RATE_LIMIT_PER_MIN=600
INFINITY_MFA_ISSUER=Infinity ID

# Logging (tracing-subscriber EnvFilter)
RUST_LOG=info,sqlx=warn
